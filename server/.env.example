# Generated by setup. Do not commit this file.
# Copy this file to .env and fill in your values before running npm run setup.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Pick ONE provider block and fill it in. Delete or comment out the others.

# Anthropic (Claude)
DEFAULT_MODEL=anthropic:claude-sonnet-4-5
DEFAULT_MODEL_KEY=sk-ant-api03-...

# OpenAI
# DEFAULT_MODEL=openai:gpt-4o
# DEFAULT_MODEL_KEY=sk-...

# OpenAI-compatible / Local (Ollama, LM Studio, llama.cpp …)
# DEFAULT_MODEL=openai-compat:http://localhost:11434/v1:llama3.2
# DEFAULT_MODEL_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Vault ─────────────────────────────────────────────────────────────────────
# Absolute path to your vault folder. Set by `npm run setup`.
COMPANION_VAULT=/Users/you/companions-vault

# ── Auth ──────────────────────────────────────────────────────────────────────
# Opaque access token. Generated automatically by `npm run setup`.
# Rotate with `npm run token:rotate-all` if you believe it was exposed.
ACCESS_TOKEN=

# ── Google Calendar (optional) ────────────────────────────────────────────────
# Required only if you want the Tracker agent to manage your calendar.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/calendar/callback
